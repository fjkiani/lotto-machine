### Layer 2 — Hook: `useOracleBrief`

**File:** `frontend/src/hooks/useOracleBrief.ts`

```ts
export interface OracleSection { summary: string; confidence: number; }
export interface OracleBrief {
  verdict: string;
  risk_level: 'HIGH' | 'MEDIUM' | 'LOW' | 'UNKNOWN';
  sections: {
    pre_signal?:   OracleSection;
    hidden_hands?: OracleSection;
    derivatives?:  OracleSection;
    kill_chain?:   OracleSection;
    regime?:       OracleSection;
  };
  trade_implication: string | null;
  generated_at: string;
}

export function useOracleBrief(masterData: MasterBrief | null) {
  // Fires once when masterData resolves (scan_time changes = new oracle call)
  // POSTs masterData to /api/v1/oracle/brief
  // Client cache keyed on masterData.scan_time (10 min max)
  // Returns { oracle, oracleLoading, oracleError }
}
```

