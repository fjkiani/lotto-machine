## The 4-Layer Plan

### Layer 1 — Backend: `/api/v1/oracle/brief`

**File:** `backend/app/api/v1/oracle.py`
**Router:** already imported in `backend/app/main.py`
**Model:** `llama-3.3-70b-versatile` via `GROQ_API_KEY` (backend only, never client)
**Caching:** `MD5(json.dumps(brief_payload, sort_keys=True))` — cache busts on ANY field change

#### Oracle Input Payload (assembled from live `/brief/master`)

```python
def build_oracle_payload(brief: dict) -> dict:
    """Extract explicit fields from /brief/master for Oracle context."""
    return {
        "timestamp": brief.get("as_of"),
        "scan_time": brief.get("scan_time"),
        "macro_regime": {
            "regime":           brief["macro_regime"].get("regime"),
            "inflation_score":  brief["macro_regime"].get("inflation_score"),
            "growth_score":     brief["macro_regime"].get("growth_score"),
            "long_penalty":     brief["macro_regime"].get("modifier", {}).get("long_penalty", 0),
            "short_penalty":    brief["macro_regime"].get("modifier", {}).get("short_penalty", 0),
        },
        "fed": {
            "current_range":  brief["fed_intelligence"]["rate_path"].get("current_range"),
            "next_meeting":   brief["fed_intelligence"]["rate_path"].get("next_meeting"),
            "days_away":      brief["fed_intelligence"]["rate_path"].get("days_away"),
            "terminal_bps":   brief["fed_intelligence"]["rate_path"].get("terminal_bps"),
        },
        "economic_veto": {
            "next_event":  brief["economic_veto"].get("next_event"),
            "hours_away":  brief["economic_veto"].get("hours_away"),
            "tier":        brief["economic_veto"].get("tier"),
        },
        "nowcast": {
            "cpi_mom":      brief["nowcast"].get("cpi_mom"),
            "core_cpi_mom": brief["nowcast"].get("core_cpi_mom"),
            "pce_mom":      brief["nowcast"].get("pce_mom"),
            "core_pce_mom": brief["nowcast"].get("core_pce_mom"),
            "cpi_yoy":      brief["nowcast"].get("cpi_yoy"),
        },
        "pre_signals": {
            "adp": {
                "prediction": brief["adp_prediction"].get("prediction"),
                "consensus":  brief["adp_prediction"].get("consensus"),
                "delta":      brief["adp_prediction"].get("delta"),
                "signal":     brief["adp_prediction"].get("signal"),
                "confidence": brief["adp_prediction"].get("confidence"),
            },
            "gdpnow": {
                "gdp_estimate": brief["gdp_nowcast"].get("gdp_estimate"),
                "consensus":    brief["gdp_nowcast"].get("consensus"),
                "vs_consensus": brief["gdp_nowcast"].get("vs_consensus"),
                "signal":       brief["gdp_nowcast"].get("signal"),
            },
            "jobless_claims": brief.get("jobless_claims", {}),
        },
        "kill_chain": {
            "alert_level":   brief["kill_chain_state"].get("alert_level"),
            "layers_active": brief["kill_chain_state"].get("layers_active"),
            "confidence_cap": brief["kill_chain_state"].get("confidence_cap"),
            "mismatches":    brief["kill_chain_state"].get("mismatches_count"),
            "narrative":     brief["kill_chain_state"].get("narrative"),
        },
        "derivatives": {
            "gex_regime":   brief["derivatives"].get("gex_regime"),
            "total_gex":    brief["derivatives"].get("total_gex"),
            "put_wall":     brief["derivatives"].get("put_wall"),
            "call_wall":    brief["derivatives"].get("call_wall"),
            "spot":         brief["derivatives"].get("spot"),
            "cot_spec_net": brief["derivatives"].get("cot_spec_net"),
            "cot_spec_side": brief["derivatives"].get("cot_spec_side"),
            "cot_divergent": brief["derivatives"].get("cot_divergent"),
        },
        "hidden_hands": {
            "politician_cluster": brief["hidden_hands"].get("politician_cluster"),
            "hot_tickers":        brief["hidden_hands"].get("hot_tickers"),
            "insider_net_usd":    brief["hidden_hands"].get("insider_net_usd"),
            "fed_tone":           brief["hidden_hands"].get("fed_tone"),
