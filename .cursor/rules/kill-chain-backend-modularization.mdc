### Fetcher Guard Decorator

```python
from functools import wraps

def layer_fetch(layer_name: str):
    def decorator(fn):
        @wraps(fn)
        def wrapper(self, *a, **kw):
            if layer_name not in self._clients:
                return None
            try:
                return fn(self, *a, **kw)
            except Exception as e:
                logger.error(f"❌ {layer_name} layer failed: {e}")
                return None
        return wrapper
    return decorator

@layer_fetch("fedwatch")
def _fetch_fedwatch(self): ...

@layer_fetch("dark_pool")
def _fetch_dark_pool(self): ...
```

