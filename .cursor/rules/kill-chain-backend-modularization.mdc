### Config Extraction (`kill_chain_config.py`)

```python
from dataclasses import dataclass, field
from typing import List

@dataclass
class KillChainConfig:
    # Symbols
    dark_pool_tickers: List[str] = field(default_factory=lambda: ["SPY"])
    cot_contract: str = "ES"
    gex_symbol: str = "SPX"
    tracked_funds: List[str] = field(default_factory=lambda: [
        "Bridgewater Associates", "Soros Fund Management", "Berkshire Hathaway"
    ])

    # Limits
    dark_pool_top_n: int = 5
    gex_wall_limit: int = 5
    gex_neg_zone_limit: int = 3

    # Cache TTL (seconds)
    short_ttl: int = 300      # dark pool, gex
    long_ttl: int = 3600      # cot, 13f

    # Mismatch thresholds
    specs_heavy_short: int = -100_000
    dark_pool_heavy_usd: float = 20e9
    short_vol_pct_threshold: float = 50.0

    # Scan
    scan_timeout_per_layer: int = 10
    fetch_parallel: bool = False
```

