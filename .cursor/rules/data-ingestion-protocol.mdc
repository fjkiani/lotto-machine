## Gate 3: CLEAN (Standardize and validate)

### Cleaning rules — apply to EVERY dataset:

```python
CLEANING_RULES = {
    # 1. Timestamps → UTC ISO-8601
    "timestamps": "Convert ALL timestamps to UTC. Store as ISO-8601 strings.",
    
    # 2. Tickers → uppercase, no whitespace
    "tickers": "Strip whitespace, uppercase. 'spy' → 'SPY', ' AAPL ' → 'AAPL'",
    
    # 3. Numeric columns → float64, NaN for missing (NOT 0, NOT -1)
    "numerics": "Cast to float64. Missing = NaN, not 0. Never use sentinel values.",
    
    # 4. Booleans → True/False (NOT 0/1, NOT 'Y'/'N')
    "booleans": "Cast to Python bool. No integer booleans.",
    
    # 5. Duplicates → drop, log count
    "duplicates": "Drop exact duplicates. Log how many removed.",
    
    # 6. Date ranges → filter to requested range only
    "date_range": "Drop rows outside requested date range. Don't silently include extras.",
}
```

### Schema enforcement — define BEFORE cleaning:

```python
# Example schema definition (one per dataset)
FINRA_SHORT_VOLUME_SCHEMA = {
    "date": "datetime",        # Trading date
    "symbol": "str",           # Ticker symbol
    "short_volume": "int64",   # Short sale volume
    "short_exempt_vol": "int64",  # Short exempt volume
    "total_volume": "int64",   # Total consolidated volume
    "market": "str",           # Market center
}

# Enforce schema
def enforce_schema(df: pd.DataFrame, schema: dict) -> pd.DataFrame:
    """Cast columns to specified types. Fail loudly on mismatch."""
    for col, dtype in schema.items():
        if col not in df.columns:
            raise ValueError(f"Missing required column: {col}")
        if dtype == "datetime":
            df[col] = pd.to_datetime(df[col], utc=True)
        elif dtype == "str":
            df[col] = df[col].astype(str).str.strip()
        else:
            df[col] = pd.to_numeric(df[col], errors='coerce').astype(dtype)
    return df
```

### Range validation — catch absurd values:

```python
RANGE_CHECKS = {
    "short_volume_pct": (0, 100),    # Can't be negative or > 100%
    "price": (0.01, 100000),         # Penny stock floor, Berkshire ceiling
    "open_interest": (0, 50_000_000),  # Sanity cap
    "delta": (-1.0, 1.0),           # Options Greek bounds
    "gamma": (0, 10.0),             # Gamma is positive
    "rsi": (0, 100),                # RSI bounds
}

def check_ranges(df: pd.DataFrame, checks: dict) -> list:
    """Flag rows with values outside expected ranges."""
    violations = []
    for col, (lo, hi) in checks.items():
        if col in df.columns:
            bad = df[(df[col] < lo) | (df[col] > hi)]
            if len(bad) > 0:
                violations.append(f"{col}: {len(bad)} rows outside [{lo}, {hi}]")
    return violations
```

