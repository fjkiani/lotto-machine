## Gate 2: SAMPLE (Smallest viable download)

### Rules:
- Download **exactly 1 file** or **1 day** or **10 rows** first
- NEVER download the full dataset before validating the sample
- Save the raw sample to `data/external/{source_name}/samples/` with timestamp

```python
# Template for sample download
def download_sample(source_name: str) -> Path:
    """Download minimal sample. Return path to raw file."""
    sample_dir = Path(f"data/external/{source_name}/samples")
    sample_dir.mkdir(parents=True, exist_ok=True)
    
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    sample_path = sample_dir / f"sample_{timestamp}.csv"
    
    # Download smallest unit (1 day, 1 page, etc.)
    # ...
    
    # Log what we got
    print(f"Sample: {sample_path}")
    print(f"Size: {sample_path.stat().st_size / 1024:.1f} KB")
    print(f"Rows: {count_rows(sample_path)}")
    
    return sample_path
```

### Sample validation — run BEFORE any larger download:
```python
def validate_sample(sample_path: Path, expected_schema: dict) -> bool:
    """Check sample matches expectations from Gate 1."""
    df = pd.read_csv(sample_path)
    
    checks = []
    
    # 1. Column names match expected
    missing = set(expected_schema.keys()) - set(df.columns)
    checks.append(("columns_present", len(missing) == 0, f"Missing: {missing}"))
    
    # 2. Not empty
    checks.append(("has_rows", len(df) > 0, f"Rows: {len(df)}"))
    
    # 3. Key columns not all null
    for col, dtype in expected_schema.items():
        if col in df.columns:
            null_pct = df[col].isna().mean()
            checks.append((f"{col}_populated", null_pct < 0.5, f"{null_pct:.0%} null"))
    
    # 4. Date column parses correctly
    date_cols = [c for c in df.columns if 'date' in c.lower() or 'time' in c.lower()]
    for dc in date_cols:
        try:
            pd.to_datetime(df[dc])
            checks.append((f"{dc}_parseable", True, "OK"))
        except:
            checks.append((f"{dc}_parseable", False, "PARSE FAIL"))
    
    # Report
    for name, passed, detail in checks:
        print(f"  {'✅' if passed else '❌'} {name}: {detail}")
    
    return all(c[1] for c in checks)
```

